{
  "name": "restaurant-ordering-saas",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant SaaS platform for restaurant ordering.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run generate:swagger && ts-node-dev --respawn --transpile-only --require tsconfig-paths/register src/server.ts",
    "build": "npm run generate:swagger && tsc",
    "generate:swagger": "ts-node scripts/generate-swagger-json.ts",
    "start": "NODE_ENV=production node dist/server.js",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:unit": "jest --runInBand",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:coverage": "jest --coverage",
    "generate:master": "DRIZZLE_CONFIG_PATH=drizzle.config.ts drizzle-kit generate",
    "generate:tenant": "DRIZZLE_CONFIG_PATH=drizzle.tenant.config.ts drizzle-kit generate",
    "migrate:master": "ts-node -r tsconfig-paths/register scripts/migrate-master.ts",
    "migrate:tenant": "ts-node -r tsconfig-paths/register scripts/migrate-tenant.ts",
    "migrate:all-tenants": "ts-node -r tsconfig-paths/register scripts/migrate-all-tenants.ts",
    "db:setup": "ts-node -r tsconfig-paths/register scripts/db-setup.ts",
    "db:reset": "ts-node -r tsconfig-paths/register scripts/db-reset.ts",
    "seed:master": "ts-node -r tsconfig-paths/register scripts/seedMaster.ts",
    "tenant:create": "ts-node -r tsconfig-paths/register scripts/createTenant.ts"
  },
  "keywords": [
    "restaurant",
    "saas",
    "multi-tenant",
    "ordering"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.7",
    "emoji-regex": "^10.6.0",
    "express": "^4.19.2",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.1.13",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/lodash": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.7.8",
    "@types/pg": "^8.15.6",
    "@types/qrcode": "^1.5.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
